# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Users are defined here as JSON. Passwords are stored in plaintext and compared
# directly. role is "learner" or "admin".
APP_USERS_JSON='[
  {
    "userKey": "user1",
    "username": "amit",
    "password": "REPLACE_WITH_PASSWORD",
    "role": "learner"
  },
  {
    "userKey": "admin1",
    "username": "admin",
    "password": "REPLACE_WITH_PASSWORD",
    "role": "admin"
  }
]'

# Long, random secret used to sign session cookies (HS256 JWT).
# Generate one with: openssl rand -base64 48
SESSION_SECRET="replace-with-a-long-random-secret"

# ---------------------------------------------------------------------------
# Supabase (optional)
# ---------------------------------------------------------------------------
# If these are not set, the app falls back to an in-memory store so it still
# runs locally (data resets on server restart). The service-role key is used
# server-side only and is never exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
